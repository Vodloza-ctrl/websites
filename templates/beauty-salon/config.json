    "hero_headline":  { "type": "text", "fallback": "Where you leave feeling beautiful." },
    "hero_subtext":   { "type": "text", "fallback": "Expert stylists, honest prices, same-day bookings on WhatsApp." },
    "hero_badge":     { "type": "text", "fallback": "Walk-ins welcome · Mon–Sat" },
    "services_intro": { "type": "text", "fallback": "Honest prices, no surprises. Walk-ins welcome when we have space." },
    "team_heading":   { "type": "text", "fallback": "Meet the team" },
    "team_subtext":   { "type": "text", "fallback": "Every stylist is trained, certified and passionate about their craft." },
    "cta_heading":    { "type": "text", "fallback": "Ready to treat yourself?" },
    "cta_subtext":    { "type": "text", "fallback": "Book on WhatsApp and we'll confirm your slot right away." },
    "address":        { "type": "text", "fallback": "" },
    "phone":          { "type": "text", "fallback": "" },
    "wa_phone":       { "type": "text", "fallback": "" },
    "hours_text":     { "type": "text", "fallback": "Mon – Sat · 9am – 6pm" },
    "map_embed_url":  { "type": "text", "fallback": "" },
    "primary_color":  { "type": "color", "fallback": "#C96A7E" }
  },
  "sections": {
    "has_gallery":          { "token": "gallery",  "minItems": 1 },
    "has_team":             { "token": "team",     "minItems": 1 },
    "has_map":              { "token": "map_embed_url", "nonEmpty": true },
    "show_booking_upsell":  { "token": "plan", "notEquals": "pro" }
  },
  "extras": [
    "services_html",
    "gallery_html",
    "team_html",
    "hours_html",
    "booking_services_json",
    "logo_img"
  ]

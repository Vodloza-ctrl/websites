{
  "templateId": "advisory-firm",
  "defaultPrimaryColor": "#C08A2D",
  "defaultTypeLabel": "Business · Legal · Advisory",
  "bodyClass": "tpl-advisory",
  "selfContainedNav": true,
  "googleFonts": "https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Sans:wght@400;500;600&display=swap",
  "typeLabels": {
    "advisory-firm":   "Business · Legal · Advisory",
    "consultant":      "Business · Tax · Advisory",
    "law-firm":        "Legal · Compliance · Advisory",
    "accountant":      "Accounting · Tax · Finance"
  },
  "scalars": [],
  "lists": [
    {
      "key": "services",
      "fallbackIcons": ["⚖️","📊","🏢","📈","🤝","💼","📋","🔍"],
      "itemTemplate": "<div class=\"service-card\"><div class=\"service-icon\">{{item.icon}}</div><h3>{{item.title}}</h3><p>{{item.body}}</p></div>"
    },
    {
      "key": "stats",
      "itemTemplate": "<div class=\"stat-item\"><div class=\"stat-value\">{{item.value}}{{item.suffix}}</div><div class=\"stat-label\">{{item.label}}</div></div>"
    },
    {
      "key": "team",
      "itemTemplate": "<div class=\"team-card\">{{#if item.photo}}<img class=\"team-photo\" src=\"{{item.photo}}\" alt=\"{{item.name}}\">{{else}}<div class=\"team-avatar\">👤</div>{{/if}}<div class=\"team-name\">{{item.name}}</div><div class=\"team-role\">{{item.role}}</div>{{#if item.bio}}<p class=\"team-bio\">{{item.bio}}</p>{{/if}}</div>"
    },
    {
      "key": "testimonials",
      "itemTemplate": "<div class=\"testi-card\"><p class=\"testi-quote\">\"{{item.text}}\"</p><div class=\"testi-name\">{{item.name}}</div><div class=\"testi-role\">{{item.role}}</div></div>"
    }
  ],
  "conditionals": [
    { "flag": "logo_url",         "type": "computed",     "token": "logo_url" },
    { "flag": "hero_image_url",   "type": "computed",     "token": "hero_image_url" },
    { "flag": "band_image_url",   "type": "computed",     "token": "band_image_url" },
    { "flag": "has_services",     "type": "list_present", "field": "services" },
    { "flag": "has_stats",        "type": "list_present", "field": "stats" },
    { "flag": "has_team",         "type": "list_present", "field": "team" },
    { "flag": "has_testimonials", "type": "list_present", "field": "testimonials" },
    { "flag": "phone",            "type": "field_present","field": "phone" },
    { "flag": "location",         "type": "field_present","field": "location" },
    { "flag": "email",            "type": "field_present","field": "email" }
  ]
}

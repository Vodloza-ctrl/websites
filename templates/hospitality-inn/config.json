{
  "templateId": "hospitality-inn",
  "name": "Hospitality Inn",
  "description": "For lodges, B&Bs, and hotels — featuring a WhatsApp booking-first experience with room categories, amenities, and availability display.",
  "defaultPalette": "navy-gold",
  "defaultPrimaryColor": "#1a1a2e",
  "defaultTypeLabel": "Lodge",
  "googleFonts": "https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,600;0,700;0,800;0,900;1,600&family=Inter:wght@300;400;500;600;700;800&display=swap",
  "bodyClass": "hospitality-inn",
  "navTextColor": "#ffffff",
  "navCtaLabel": "Book Now",
  "selfContainedNav": false,
  "showOpenBadge": true,
  "showHoursGrid": true,
  "typeLabels": {
    "hospitality-inn": "Lodge"
  },
  "extraTokens": {
    "hi_hero_badge": "🏨 Book Direct — Best Price Guaranteed",
    "hi_hero_headline": "Your Home Away From Home",
    "hi_hero_subtext": "Comfortable rooms, warm hospitality, and a location that makes your stay unforgettable."
  },
  "navLinks": [
    "#rooms:Rooms",
    "#about:About",
    "#gallery:Gallery",
    "#testimonials:Reviews",
    "#contact:Contact"
  ],
  "lists": [
    {
      "key": "rooms",
      "itemTemplate": `<div class="room-card{{#if @first}}{{#if ../has_featured_room}} highlighted{{/if}}{{/if}} reveal">
        {{#if @first}}
          {{#if tag}}
            <span class="feat-badge">✦ {{tag}}</span>
          {{/if}}
        {{/if}}
        <div class="room-photo">
          {{#if photo}}
            <img src="{{photo}}" alt="{{name}}" loading="lazy">
          {{else}}
            <div class="room-photo-ph">🏨</div>
          {{/if}}
          <span class="room-status {{status}}">
            {{#if_eq status "available"}}✓ Available{{/if_eq}}
            {{#if_eq status "limited"}}⚠ Limited{{/if_eq}}
            {{#if_eq status "booked"}}✗ Booked{{/if_eq}}
            {{#unless status}}✓ Available{{/unless}}
          </span>
        </div>
        <div class="room-body">
          <div class="room-head">
            <div class="room-name">{{name}}</div>
            <div class="room-price">{{price}} <span class="room-price-unit">/night</span></div>
          </div>
          {{#if description}}
            <p class="room-desc">{{description}}</p>
          {{/if}}
          {{#if amenities}}
            <div class="room-amenities">
              {{#each amenities}}
                <span class="room-amenity">• {{this}}</span>
              {{/each}}
            </div>
          {{/if}}
          {{#if_eq status "booked"}}
            <button class="room-book-btn booked" disabled>Fully Booked</button>
          {{else}}
            <a href="{{../whatsapp_wa_link}}?text={{urlencode (concat 'Hello, I would like to book: ' name ' - ' price '/night')}}" class="room-book-btn" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" width="14" height="14" fill="#fff" stroke="none"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
              Book Now
            </a>
          {{/if_eq}}
        </div>
      </div>`,
      "emptyHtml": `<div style="text-align:center;padding:40px 0;opacity:0.5;"><p>Room details coming soon. Contact us directly to book.</p></div>`
    },
    {
      "key": "gallery",
      "itemTemplate": `<div class="gallery-item reveal"><img src="{{this}}" alt="Gallery photo" loading="lazy"></div>`,
      "emptyHtml": `<div style="text-align:center;padding:40px 0;opacity:0.5;"><p>Gallery photos coming soon.</p></div>`
    },
    {
      "key": "testimonials",
      "itemTemplate": `<div class="testimonial-card reveal">
        <div class="testi-stars">★★★★★</div>
        <p class="testi-text">"{{text}}"</p>
        <div class="testi-author">
          {{#if photo}}
            <div class="testi-avatar"><img src="{{photo}}" alt="{{name}}" loading="lazy"></div>
          {{else}}
            <div class="testi-avatar-placeholder">{{name_char}}</div>
          {{/if}}
          <div>
            <div class="testi-name">{{name}}</div>
            {{#if role}}<div class="testi-role">{{role}}</div>{{/if}}
          </div>
        </div>
      </div>`,
      "emptyHtml": `<div style="text-align:center;padding:40px 0;opacity:0.5;"><p>Guest reviews coming soon.</p></div>`
    },
    {
      "key": "hours",
      "itemTemplate": `<div class="hours-row{{#if this.is_today}} today{{/if}}">
        <span class="day">{{this.day}}{{#if this.is_today}}<span class="today-pill">Today</span>{{/if}}</span>
        <span class="time">{{this.hours}}</span>
      </div>`,
      "emptyHtml": ""
    },
    {
      "key": "stats",
      "itemTemplate": `<div class="stat"><span class="stat-number">{{this.value}}{{this.suffix}}</span><span class="stat-label">{{this.label}}</span></div>`,
      "emptyHtml": ""
    }
  ],
  "conditionals": [
    {
      "flag": "has_rooms",
      "type": "list_present",
      "field": "rooms"
    },
    {
      "flag": "has_gallery",
      "type": "list_present",
      "field": "gallery"
    },
    {
      "flag": "has_testimonials",
      "type": "list_present",
      "field": "testimonials"
    },
    {
      "flag": "has_stats",
      "type": "list_present",
      "field": "stats"
    },
    {
      "flag": "has_featured_room",
      "type": "computed",
      "token": "has_featured_room"
    }
  ]
}

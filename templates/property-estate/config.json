{
  "templateId": "property-estate",
  "defaultPrimaryColor": "#13392A",
  "defaultTypeLabel": "Property · Sales · Rentals",
  "bodyClass": "tpl-property",
  "selfContainedNav": true,
  "googleFonts": "https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap",
  "typeLabels": {
    "property-estate": "Property · Sales · Rentals",
    "realestate":      "Property · Sales · Rentals",
    "estate-agent":    "Estate Agency · Valuations"
  },
  "scalars": [],
  "lists": [
    {
      "key": "listings",
      "emptyHtml": "<div style=\"grid-column:1/-1;text-align:center;padding:48px 20px;color:#5E6B63;font-size:.95rem\">No listings yet — add properties in your dashboard.</div>",
      "itemTemplate": "<div class=\"prop-card\"><div class=\"prop-photo\">{{#if item.photos_html}}{{item.photos_html}}{{else}}{{#if item.photo}}<img src=\"{{item.photo}}\" alt=\"{{item.name}}\">{{else}}<div class=\"prop-photo-ph\"><svg viewBox=\"0 0 24 24\" width=\"40\" height=\"40\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"opacity:.35\"><path d=\"m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z\"/><polyline points=\"9 22 9 12 15 12 15 22\"/></svg></div>{{/if}}{{/if}}<span class=\"prop-badge {{item.badge_class}}\">{{item.type_label}}</span></div><div class=\"prop-body\"><div class=\"prop-price\">{{item.price}}</div><div class=\"prop-name\">{{item.name}}</div><div class=\"prop-loc\">{{item.address}}</div>{{#if item.description}}<p class=\"prop-desc\">{{item.description}}</p>{{/if}}<div class=\"prop-features\">{{item.features_html}}</div><div class=\"prop-actions\"><a href=\"{{item.wa_link}}\" class=\"enq-btn\" target=\"_blank\" rel=\"noopener\">Enquire</a><a href=\"{{item.wa_link}}\" class=\"enq-wa\" target=\"_blank\" rel=\"noopener\"><svg viewBox=\"0 0 24 24\" width=\"17\" height=\"17\" fill=\"currentColor\" stroke=\"none\" aria-hidden=\"true\"><path d=\"M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z\"/></svg></a></div></div></div>"
    },
    {
      "key": "team",
      "itemTemplate": "<div class=\"agent-card\">{{#if item.photo}}<img class=\"agent-photo\" src=\"{{item.photo}}\" alt=\"{{item.name}}\">{{else}}<div class=\"agent-avatar\"><svg viewBox=\"0 0 24 24\" width=\"36\" height=\"36\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2\"/><circle cx=\"12\" cy=\"7\" r=\"4\"/></svg></div>{{/if}}<div class=\"agent-name\">{{item.name}}</div><div class=\"agent-role\">{{item.role}}</div>{{#if item.bio}}<p class=\"agent-bio\">{{item.bio}}</p>{{/if}}</div>"
    }
  ],
  "conditionals": [
    { "flag": "logo_url",       "type": "computed",      "token": "logo_url" },
    { "flag": "hero_image_url", "type": "computed",      "token": "hero_image_url" },
    { "flag": "has_agents",     "type": "list_present",  "field": "team" },
    { "flag": "phone",          "type": "field_present", "field": "phone" },
    { "flag": "location",       "type": "field_present", "field": "location" },
    { "flag": "email",          "type": "field_present", "field": "email" }
  ]
}

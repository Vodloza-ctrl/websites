{
  "templateId": "property-estate",
  "defaultPrimaryColor": "#13392A",
  "defaultTypeLabel": "Property · Sales · Rentals",
  "bodyClass": "tpl-property",
  "selfContainedNav": true,
  "googleFonts": "https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap",
  "typeLabels": {
    "property-estate": "Property · Sales · Rentals",
    "realestate":      "Property · Sales · Rentals",
    "estate-agent":    "Estate Agency · Valuations"
  },
  "scalars": [],
  "lists": [
    {
      "key": "listings",
      "emptyHtml": "<div style=\"grid-column:1/-1;text-align:center;padding:48px 20px;color:#5E6B63;font-size:.95rem\">No listings yet — add properties in your dashboard.</div>",
      "itemTemplate": "<div class=\"prop-card\"><div class=\"prop-photo\">{{#if item.photos_html}}{{item.photos_html}}{{else}}{{#if item.photo}}<img src=\"{{item.photo}}\" alt=\"{{item.name}}\">{{else}}<div class=\"prop-photo-ph\"><svg viewBox=\"0 0 24 24\" width=\"40\" height=\"40\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"opacity:.35\"><path d=\"m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z\"/><polyline points=\"9 22 9 12 15 12 15 22\"/></svg></div>{{/if}}{{/if}}<span class=\"prop-badge {{item.badge_class}}\">{{item.type_label}}</span></div><div class=\"prop-body\"><div class=\"prop-price\">{{item.price}}</div><div class=\"prop-name\">{{item.name}}</div><div class=\"prop-loc\">{{item.address}}</div>{{#if item.description}}<p class=\"prop-desc\">{{item.description}}</p>{{/if}}<div class=\"prop-features\">{{item.features_html}}</div><div class=\"prop-actions\"><a href=\"{{item.wa_link}}\" class=\"enq-btn\" target=\"_blank\" rel=\"noopener\">Enquire</a><a href=\"{{item.wa_link}}\" class=\"enq-wa\" target=\"_blank\" rel=\"noopener\"><svg viewBox=\"0 0 24 24\" width=\"17\" height=\"17\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z\"/></svg></a></div></div></div>"
    },
    {
      "key": "team",
      "itemTemplate": "<div class=\"agent-card\">{{#if item.photo}}<img class=\"agent-photo\" src=\"{{item.photo}}\" alt=\"{{item.name}}\">{{else}}<div class=\"agent-avatar\"><svg viewBox=\"0 0 24 24\" width=\"36\" height=\"36\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2\"/><circle cx=\"12\" cy=\"7\" r=\"4\"/></svg></div>{{/if}}<div class=\"agent-name\">{{item.name}}</div><div class=\"agent-role\">{{item.role}}</div>{{#if item.bio}}<p class=\"agent-bio\">{{item.bio}}</p>{{/if}}</div>"
    }
  ],
  "conditionals": [
    { "flag": "logo_url",       "type": "computed",      "token": "logo_url" },
    { "flag": "hero_image_url", "type": "computed",      "token": "hero_image_url" },
    { "flag": "has_agents",     "type": "list_present",  "field": "team" },
    { "flag": "phone",          "type": "field_present", "field": "phone" },
    { "flag": "location",       "type": "field_present", "field": "location" },
    { "flag": "email",          "type": "field_present", "field": "email" }
  ]
}

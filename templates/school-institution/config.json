{
  "template_id": "school-institution",
  "name": "School & Institution",
  "description": "For schools, churches, sports clubs, and community organisations",
  "palette": "navy-gold",
  "font_pair": "fraunces-jakarta",
  "sections": ["hero", "about", "programmes", "team", "events", "gallery", "shop", "testimonials", "contact"],
  "tokens": {
    "business_name": "Sunrise Academy",
    "tagline": "Shaping Tomorrow's Leaders Today",
    "about_text": "We are committed to nurturing excellence in every student through world-class education, character development, and a vibrant learning community.",
    "hero_image_url": "",
    "logo_url": "",
    "phone": "+263 77 000 0000",
    "email": "info@sunriseacademy.ac.zw",
    "address": "14 Academy Drive, Bulawayo",
    "whatsapp": "+263770000000",
    "facebook_url": "",
    "instagram_url": "",
    "twitter_url": "",
    "stat_1_number": "1 200",
    "stat_1_label": "Students Enrolled",
    "stat_2_number": "98%",
    "stat_2_label": "Pass Rate",
    "stat_3_number": "45",
    "stat_3_label": "Years of Excellence",
    "stat_4_number": "120",
    "stat_4_label": "Teaching Staff"
  },
  "flags": {
    "show_stats": true,
    "show_programmes": true,
    "show_team": true,
    "show_events": true,
    "show_gallery": true,
    "show_shop": true,
    "show_testimonials": true
  },
  "lists": [
    {
      "key": "programmes",
      "emptyHtml": "<p style='text-align:center;padding:40px;color:var(--muted)'>No programmes listed yet. Check back soon.</p>",
      "itemTemplate": "<div class=\"si-prog\"><div class=\"si-prog__img\">{{#if item.photo}}<img src=\"{{item.photo}}\" alt=\"{{item.name}}\">{{/if}}</div><div class=\"si-prog__body\">{{#if item.category}}<div class=\"si-prog__cat\">{{item.category}}</div>{{/if}}<div class=\"si-prog__name\">{{item.name}}</div><div class=\"si-prog__desc\">{{item.description}}</div>{{#if item.price}}<div class=\"si-prog__price\">{{item.price}}</div>{{/if}}</div></div>"
    },
    {
      "key": "team",
      "emptyHtml": "<p style='text-align:center;padding:40px;color:var(--muted)'>Our team will be listed here soon.</p>",
      "itemTemplate": "<div class=\"si-member\"><div class=\"si-member__photo\">{{#if item.photo}}<img src=\"{{item.photo}}\" alt=\"{{item.name}}\">{{/if}}</div><div class=\"si-member__name\">{{item.name}}</div><div class=\"si-member__role\">{{item.role}}</div><div class=\"si-member__bio\">{{item.bio}}</div></div>"
    },
    {
      "key": "events",
      "emptyHtml": "<p style='text-align:center;padding:40px;color:var(--muted)'>No events scheduled. Stay tuned!</p>",
      "itemTemplate": "<div class=\"si-event\"><div class=\"si-event__date\">{{#if item.date}}<div class=\"si-event__day\">{{item.date}}</div>{{/if}}</div><div><div class=\"si-event__title\">{{item.title}}</div>{{#if item.meta}}<div class=\"si-event__meta\">{{item.meta}}</div>{{/if}}<div class=\"si-event__desc\">{{item.description}}</div></div></div>"
    },
    {
      "key": "gallery",
      "emptyHtml": "",
      "itemTemplate": "<div class=\"si-gallery__item\"><img src=\"{{item.url}}\" alt=\"{{item.caption}}\"></div>"
    },
    {
      "key": "testimonials",
      "emptyHtml": "<p style='text-align:center;padding:40px;color:var(--muted)'>No testimonials yet. Share your experience!</p>",
      "itemTemplate": "<div class=\"si-testi\"><div class=\"si-testi__text\">{{item.text}}</div><div class=\"si-testi__author\">{{#if item.photo}}<div class=\"si-testi__avatar\"><img src=\"{{item.photo}}\" alt=\"{{item.name}}\"></div>{{/if}}<div><div class=\"si-testi__name\">{{item.name}}</div><div class=\"si-testi__role\">{{item.role}}</div></div></div></div>"
    }
  ],
  "conditionals": [
    {
      "flag": "show_stats",
      "type": "content_flag",
      "field": "show_stats",
      "default": true
    },
    {
      "flag": "show_programmes",
      "type": "list_present",
      "field": "programmes"
    },
    {
      "flag": "show_team",
      "type": "list_present",
      "field": "team"
    },
    {
      "flag": "show_events",
      "type": "list_present",
      "field": "events"
    },
    {
      "flag": "show_gallery",
      "type": "list_present",
      "field": "gallery"
    },
    {
      "flag": "show_shop",
      "type": "list_present",
      "field": "products"
    },
    {
      "flag": "show_testimonials",
      "type": "list_present",
      "field": "testimonials"
    },
    {
      "flag": "has_logo",
      "type": "field_present",
      "field": "logo_url"
    },
    {
      "flag": "has_hero",
      "type": "field_present",
      "field": "hero_image_url"
    },
    {
      "flag": "has_phone",
      "type": "field_present",
      "field": "phone"
    },
    {
      "flag": "has_email",
      "type": "field_present",
      "field": "email"
    },
    {
      "flag": "has_address",
      "type": "field_present",
      "field": "address"
    },
    {
      "flag": "has_whatsapp",
      "type": "field_present",
      "field": "whatsapp"
    },
    {
      "flag": "has_facebook",
      "type": "field_present",
      "field": "facebook_url"
    },
    {
      "flag": "has_instagram",
      "type": "field_present",
      "field": "instagram_url"
    },
    {
      "flag": "has_twitter",
      "type": "field_present",
      "field": "twitter_url"
    }
  ],
  "typeLabels": {
    "school-institution": "School",
    "church": "Church",
    "sports": "Sports Academy"
  },
  "defaultTypeLabel": "Institution"
}

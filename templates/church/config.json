<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>{{seo_title}}</title>
<meta name="description" content="{{seo_description}}">
<meta property="og:title" content="{{business_name}}">
<meta property="og:description" content="{{seo_description}}">
<meta property="og:image" content="{{hero_image_url}}">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
{{wcz_commerce_css}}
<style>
:root{
  --warm: #2C1A0E;
  --warm2: #4A2E1A;
  --warm3: #1A0F08;
  --amber: #C07A2B;
  --amber2: #E09A3B;
  --amber3: #F5B84A;
  --cream: #FAF5EE;
  --cream2: #F0E8DD;
  --ink: #241A10;
  --ink2: #6A5A44;
  --ink3: #9A8A74;
  --paper: #fff;
  --line: rgba(44,26,14,.12);
  --line2: rgba(44,26,14,.22);
  --r: 12px;
  --r-sm: 8px;
  --display: "Fraunces", serif;
  --sans: "Plus Jakarta Sans", sans-serif;
  --shadow: 0 4px 24px rgba(44,26,14,.08);
  --shadow-lg: 0 20px 60px rgba(44,26,14,.15);
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;-webkit-font-smoothing:antialiased;font-size:16px}
body{font-family:var(--sans);background:var(--cream);color:var(--ink);line-height:1.65;overflow-x:hidden}
img{max-width:100%;height:auto;display:block}
a{color:inherit;text-decoration:none}
button{cursor:pointer;border:none;background:none;font:inherit;color:inherit}
ul{list-style:none}
::selection{background:var(--amber);color:#fff}

.wrap{max-width:1120px;margin:0 auto;padding:0 26px}
.eyebrow{font-family:var(--sans);font-size:.8rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--amber);display:flex;align-items:center;gap:10px}
.eyebrow::before{content:'';display:block;width:28px;height:2px;background:var(--amber)}
.eyebrow-center{text-align:center;justify-content:center}
.eyebrow-center::before{display:none}

/* ── NAV ────────────────────────────────────────────────*/
#nav{
  position:fixed;top:0;left:0;right:0;z-index:100;height:72px;
  padding:0 24px;display:flex;align-items:center;justify-content:space-between;
  background:rgba(250,245,238,0);border-bottom:1px solid transparent;
  transition:background .35s,border-color .35s,backdrop-filter .35s;
}
#nav.scrolled{background:rgba(250,245,238,.93);backdrop-filter:blur(14px);border-bottom-color:var(--line)}
.nav-logo{font-family:var(--display);font-size:1.08rem;font-weight:700;display:flex;align-items:center;gap:10px}
.nav-logo .cross{width:32px;height:32px;border-radius:8px;background:var(--warm);display:grid;place-items:center;flex:none}
.nav-logo .cross svg{width:14px;height:14px;fill:var(--amber)}
.nav-logo img{height:32px;width:auto;object-fit:contain}
.nav-links{display:flex;align-items:center;gap:28px}
.nav-links a{font-size:.9rem;font-weight:500;color:var(--ink2);transition:color .2s}
.nav-links a:hover{color:var(--warm)}
.nav-cta{
  font-family:var(--sans);font-size:.8rem;font-weight:600;
  padding:10px 20px;background:var(--warm);color:#fff;border-radius:var(--r-sm);
  transition:background .2s,transform .1s;display:flex;align-items:center;gap:8px;
}
.nav-cta:hover{background:var(--amber);transform:translateY(-1px)}
.nav-wa{
  font-family:var(--sans);font-size:.75rem;font-weight:600;
  padding:9px 16px;background:#25D366;color:#fff;border-radius:var(--r-sm);
  transition:background .2s,transform .1s;display:flex;align-items:center;gap:8px;
}
.nav-wa:hover{background:#1a9e4e;transform:translateY(-1px)}
.nav-ham{display:none;flex-direction:column;gap:5px;padding:4px;cursor:pointer}
.nav-ham span{display:block;width:22px;height:1.5px;background:var(--ink)}
#nav-mob{
  display:none;position:fixed;inset:0;z-index:99;background:var(--cream);
  flex-direction:column;align-items:center;justify-content:center;gap:24px;
}
#nav-mob.open{display:flex}
#nav-mob a{font-family:var(--display);font-size:1.3rem;font-weight:600;color:var(--ink)}
#nav-mob a:hover{color:var(--amber)}
.mob-close{position:absolute;top:26px;right:26px;font-size:1.4rem;opacity:.5;cursor:pointer}

/* ── HERO ────────────────────────────────────────────────*/
#hero{position:relative;min-height:72vh;display:flex;align-items:center;color:#fff;padding-top:72px}
#hero .hero-bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0}
#hero::after{content:"";position:absolute;inset:0;background:linear-gradient(0deg,rgba(44,26,14,.85) 0%,rgba(44,26,14,.3) 70%);z-index:1}
.hero-wrap{position:relative;z-index:2;padding:60px 26px;width:100%}
.hero-eyebrow{font-size:.8rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--amber2)}
.hero-h1{font-family:var(--display);font-size:clamp(2.4rem,5.5vw,4.2rem);font-weight:700;line-height:1.08;margin:14px 0 18px;max-width:18ch}
.hero-sub{font-size:1.12rem;max-width:44ch;color:rgba(255,255,255,.88);line-height:1.7}
.hero-actions{display:flex;gap:14px;margin-top:28px;flex-wrap:wrap}
.hero-actions .btn-ghost{background:rgba(255,255,255,.12);border:1.5px solid rgba(255,255,255,.4);color:#fff}
.hero-actions .btn-ghost:hover{background:rgba(255,255,255,.25)}

/* ── SECTION SCAFFOLD ────────────────────────────────────*/
section.pane{padding:72px 0}
section.pane-alt{background:var(--paper);padding:72px 0}
.sec-head{text-align:center;max-width:640px;margin:0 auto 48px}
.sec-head h2{font-family:var(--display);font-size:clamp(1.9rem,3.5vw,2.8rem);font-weight:600;margin-top:10px;line-height:1.1}
.sec-head p{color:var(--ink2);margin-top:10px;font-size:1.05rem}

.btn{display:inline-flex;align-items:center;gap:8px;font-weight:600;font-size:.9rem;padding:12px 24px;border-radius:var(--r-sm);transition:background .2s,transform .1s;border:none;cursor:pointer}
.btn-primary{background:var(--warm);color:#fff}
.btn-primary:hover{background:var(--amber);transform:translateY(-1px)}
.btn-outline{background:transparent;border:1.5px solid var(--warm);color:var(--warm)}
.btn-outline:hover{background:var(--warm);color:#fff}
.btn-wa{background:#25D366;color:#fff}
.btn-wa:hover{background:#1a9e4e;transform:translateY(-1px)}
.btn-ghost{background:rgba(255,255,255,.12);border:1.5px solid rgba(255,255,255,.4);color:#fff}
.btn-ghost:hover{background:rgba(255,255,255,.25)}

/* ── SERVICE TIMES BAR ──────────────────────────────────*/
.times-bar{background:var(--warm);color:#fff;padding:14px 0}
.times-grid{display:flex;align-items:center;gap:40px;flex-wrap:wrap}
.time-item .label{font-size:.7rem;text-transform:uppercase;letter-spacing:.1em;color:var(--amber2);font-weight:700;display:block}
.time-item .val{font-weight:600;font-size:.96rem}

/* ── VALUES / CORE ──────────────────────────────────────*/
.values-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:20px}
.vcard{background:var(--paper);border:1px solid var(--line);border-radius:var(--r);padding:28px 24px;text-align:center;transition:box-shadow .2s,transform .2s}
.vcard:hover{box-shadow:var(--shadow);transform:translateY(-2px)}
.vcard .icon{width:52px;height:52px;border-radius:12px;background:var(--cream);display:grid;place-items:center;font-size:1.5rem;margin:0 auto 16px}
.vcard h3{font-family:var(--display);font-size:1.1rem;margin-bottom:8px}
.vcard p{font-size:.9rem;color:var(--ink2);line-height:1.5}

/* ── PASTOR / LEADERSHIP ────────────────────────────────*/
.pastor-grid{display:grid;grid-template-columns:.9fr 1.1fr;gap:56px;align-items:center}
.pastor-img{width:100%;border-radius:var(--r);aspect-ratio:4/4.5;object-fit:cover;box-shadow:var(--shadow-lg)}
.pastor-kicker{font-size:.8rem;letter-spacing:.14em;text-transform:uppercase;color:var(--amber);font-weight:700}
.pastor-grid h2{font-family:var(--display);font-size:clamp(1.8rem,3vw,2.6rem);margin:12px 0 16px}
.pastor-grid p{color:var(--ink2);font-size:1.02rem;line-height:1.7;margin-bottom:12px}

/* ── MINISTRIES ──────────────────────────────────────────*/
.min-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:18px}
.mcard{border:1px solid var(--line);border-radius:var(--r);padding:22px 24px;display:flex;gap:16px;align-items:flex-start;background:var(--paper);transition:box-shadow .2s}
.mcard:hover{box-shadow:var(--shadow)}
.mcard .ico{width:44px;height:44px;border-radius:10px;background:var(--cream);display:grid;place-items:center;font-size:1.2rem;flex:none}
.mcard h3{font-family:var(--display);font-size:1rem;margin-bottom:6px}
.mcard p{font-size:.88rem;color:var(--ink2);line-height:1.5}

/* ── EVENTS ──────────────────────────────────────────────*/
.events-list{display:flex;flex-direction:column;gap:12px}
.event-item{display:grid;grid-template-columns:56px 1fr auto;gap:16px;align-items:center;background:var(--paper);border:1px solid var(--line);border-radius:var(--r);padding:16px 20px;transition:box-shadow .2s}
.event-item:hover{box-shadow:var(--shadow)}
.event-date{text-align:center;background:var(--warm);border-radius:var(--r-sm);padding:6px 0;color:#fff;min-width:48px}
.event-date .day{font-family:var(--display);font-size:1.4rem;font-weight:600;line-height:1}
.event-date .month{font-size:.62rem;text-transform:uppercase;letter-spacing:.1em}
.event-info h3{font-size:.96rem;font-weight:600}
.event-info p{font-size:.84rem;color:var(--ink2);margin-top:2px}
.event-tag{font-size:.7rem;font-weight:700;padding:4px 12px;border-radius:6px;background:var(--cream);color:var(--warm);white-space:nowrap}

/* ── GIVING BANNER ──────────────────────────────────────*/
.give-band{background:var(--warm);color:#fff;text-align:center;border-radius:var(--r);padding:54px 40px}
.give-band .eyebrow{color:var(--amber2);justify-content:center}
.give-band .eyebrow::before{display:none}
.give-band h2{font-family:var(--display);font-size:clamp(2rem,3.5vw,2.8rem);margin:10px 0 14px}
.give-band p{color:rgba(255,255,255,.8);max-width:44ch;margin:0 auto 28px;font-size:1.05rem;line-height:1.7}
.give-band .btn-white{background:#fff;color:var(--warm)}
.give-band .btn-white:hover{background:var(--amber2);color:#fff}

/* ── LOCATION ────────────────────────────────────────────*/
.location-grid{display:grid;grid-template-columns:1.3fr .7fr;gap:40px;align-items:center}
.location-map{background:linear-gradient(135deg,#e8e0d8 0%,#d5cbc0 100%);border-radius:var(--r);aspect-ratio:16/10;overflow:hidden;border:1px solid var(--line);display:grid;place-items:center;color:var(--ink3);font-size:1.4rem;position:relative}
.location-map iframe{width:100%;height:100%;border:0}
.location-map .map-placeholder{font-size:2.6rem;opacity:.4}
.address-box h3{font-family:var(--display);font-size:1.4rem;margin-bottom:16px}
.addr-row{display:flex;gap:12px;align-items:flex-start;margin-bottom:14px}
.addr-row .ico{font-size:1.1rem;margin-top:2px;flex:none;width:22px;text-align:center}
.addr-row p{font-size:.92rem;color:var(--ink2);line-height:1.5}

/* ── COMMERCE / PRODUCTS ──────────────────────────────────*/
.cat-filter-bar{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:36px}
.cat-filter-bar .fr-cat{
  font-family:var(--sans);font-size:.7rem;letter-spacing:.08em;text-transform:uppercase;
  padding:8px 18px;border:1px solid var(--line2);border-radius:20px;color:var(--ink2);
  cursor:pointer;transition:border-color .15s,background .15s,color .15s;background:transparent;
}
.cat-filter-bar .fr-cat:hover{border-color:var(--warm)}
.cat-filter-bar .fr-cat.active{border-color:var(--amber);color:var(--amber);background:rgba(192,122,43,.08)}

/* ── TESTIMONIALS ────────────────────────────────────── */
.testi-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:18px}
.testi-card{background:var(--paper);border:1px solid var(--line);border-radius:var(--r);padding:28px 26px}
.testi-stars{display:flex;gap:2px;color:var(--amber);font-size:.9rem;margin-bottom:12px}
.testi-text{font-size:.96rem;line-height:1.7;color:var(--ink2);margin-bottom:18px}
.testi-author{display:flex;align-items:center;gap:12px}
.testi-avatar{width:38px;height:38px;border-radius:50%;background:var(--warm);color:#fff;display:grid;place-items:center;font-weight:700;font-size:.75rem;overflow:hidden;flex:none}
.testi-avatar img{width:100%;height:100%;object-fit:cover}
.testi-name{font-weight:600;font-size:.9rem}
.testi-role{font-size:.78rem;color:var(--ink2)}

/* ── TEAM ────────────────────────────────────────────── */
.team-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:18px}
.team-card{background:var(--paper);border:1px solid var(--line);border-radius:var(--r);overflow:hidden;text-align:center;transition:box-shadow .2s}
.team-card:hover{box-shadow:var(--shadow)}
.team-photo{aspect-ratio:1/1;overflow:hidden;background:var(--warm)}
.team-photo img{width:100%;height:100%;object-fit:cover}
.team-info{padding:16px 14px 20px}
.team-name{font-family:var(--display);font-size:1rem;font-weight:600}
.team-role{font-size:.78rem;color:var(--ink2);margin-top:4px}
.team-bio{font-size:.84rem;color:var(--ink3);margin-top:8px;line-height:1.5}

/* ── GALLERY ─────────────────────────────────────────── */
.gallery-grid{display:grid;grid-template-columns:repeat(4,1fr);grid-auto-rows:180px;gap:4px}
.gallery-grid .g-item{overflow:hidden;cursor:pointer;background:var(--warm)}
.gallery-grid .g-item img{width:100%;height:100%;object-fit:cover;opacity:.92;transition:transform .4s,opacity .3s}
.gallery-grid .g-item:hover img{transform:scale(1.04);opacity:1}
.gallery-grid .g-item:nth-child(1){grid-column:span 2;grid-row:span 2}

/* ── GALLERY LIGHTBOX ────────────────────────────────────*/
#lb{
  position:fixed;inset:0;z-index:300;background:rgba(44,26,14,.94);display:none;
  align-items:center;justify-content:center;padding:40px;
}
#lb.open{display:flex}
#lb img{max-width:min(1000px,90vw);max-height:84vh;object-fit:contain;border-radius:var(--r-sm)}
#lb-close,#lb-prev,#lb-next{
  position:absolute;color:#fff;font-size:1.4rem;width:46px;height:46px;display:flex;align-items:center;justify-content:center;
  border:1px solid rgba(255,255,255,.2);border-radius:50%;transition:background .2s;background:rgba(0,0,0,.3);
}
#lb-close:hover,#lb-prev:hover,#lb-next:hover{background:rgba(255,255,255,.12)}
#lb-close{top:26px;right:26px}
#lb-prev{left:26px;top:50%;transform:translateY(-50%)}
#lb-next{right:26px;top:50%;transform:translateY(-50%)}

/* ── CONTACT ─────────────────────────────────────────── */
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:start}
.contact-info{display:flex;flex-direction:column;gap:20px}
.cinfo-item{display:flex;gap:14px;align-items:flex-start}
.cinfo-icon{width:40px;height:40px;flex:none;border:1px solid var(--line);border-radius:var(--r-sm);display:grid;place-items:center;color:var(--ink2);font-size:1rem}
.cinfo-label{font-size:.7rem;text-transform:uppercase;letter-spacing:.08em;color:var(--amber);font-weight:700}
.cinfo-val{font-size:.95rem;color:var(--ink2);line-height:1.5}
.contact-cta{background:var(--warm);color:#fff;border-radius:var(--r);padding:42px 36px}
.contact-cta .eyebrow{color:var(--amber2)}
.contact-cta .eyebrow::before{background:var(--amber2)}
.contact-cta h3{font-family:var(--display);font-size:1.6rem;margin:12px 0 16px}
.contact-cta p{opacity:.8;line-height:1.7;margin-bottom:24px;font-size:.95rem}

/* ── FOOTER ──────────────────────────────────────────── */
footer{background:var(--warm);color:rgba(255,255,255,.75);padding:36px 0}
.footer-inner{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px}
.footer-brand{font-family:var(--display);font-size:1rem;font-weight:700;color:#fff}
.footer-links{display:flex;gap:20px}
.footer-links a{font-size:.82rem;color:rgba(255,255,255,.6);transition:color .2s}
.footer-links a:hover{color:#fff}
.footer-social{display:flex;gap:8px}
.footer-social a{width:34px;height:34px;border-radius:var(--r-sm);border:1px solid rgba(255,255,255,.2);display:grid;place-items:center;color:#fff;font-size:.8rem;transition:background .2s}
.footer-social a:hover{background:rgba(255,255,255,.1)}
.footer-copy{font-size:.78rem;color:rgba(255,255,255,.4);width:100%;text-align:center;margin-top:16px;padding-top:16px;border-top:1px solid rgba(255,255,255,.06)}

/* ── REVEAL ──────────────────────────────────────────── */
.reveal{opacity:0;transform:translateY(20px);transition:opacity .55s ease,transform .55s ease}
.reveal.visible{opacity:1;transform:translateY(0)}

/* ── RESPONSIVE ──────────────────────────────────────── */
@media(max-width:900px){
  .pastor-grid{grid-template-columns:1fr;gap:32px}
  .pastor-img{aspect-ratio:16/9}
  .location-grid{grid-template-columns:1fr}
  .nav-links{display:none}
  .nav-cta{display:none}
  .nav-ham{display:flex}
  .times-grid{gap:20px}
  .gallery-grid{grid-template-columns:repeat(2,1fr)}
  .gallery-grid .g-item:nth-child(1){grid-column:span 1;grid-row:span 1}
  .contact-grid{grid-template-columns:1fr}
}
@media(max-width:600px){
  .values-grid{grid-template-columns:1fr}
  .min-grid{grid-template-columns:1fr}
  .event-item{grid-template-columns:1fr;gap:12px;text-align:center}
  .event-date{display:inline-flex;padding:4px 12px;gap:8px}
  .event-date .month{font-size:.7rem}
  .event-tag{align-self:center}
  .give-band{padding:36px 24px}
  .hero-wrap{padding:30px 20px}
  .hero-h1{font-size:2rem}
}
@media(prefers-reduced-motion:reduce){
  .reveal{opacity:1;transform:none;transition:none}
  *{transition-duration:.01ms!important}
}
</style>
</head>
<body>

<!-- NAV -->
<nav id="nav">
  <a class="nav-logo" href="#">
    <span class="cross">
      <svg viewBox="0 0 16 16" fill="none"><rect x="6.5" y="1" width="3" height="14" rx="1.2" fill="currentColor"/><rect x="1" y="5.5" width="14" height="3" rx="1.2" fill="currentColor"/></svg>
    </span>
    {{#if has_logo}}<img src="{{logo_url}}" alt="{{business_name}}">{{/if}}
    {{business_name}}
  </a>
  <div class="nav-links">
    <a href="#about">About</a>
    <a href="#ministries">Ministries</a>
    <a href="#events">Events</a>
    <a href="#give">Give</a>
    {{#if has_products}}<a href="#shop">Shop</a>{{/if}}
    <a href="#contact">Contact</a>
    <button class="nav-wa" id="wcz-nav-cart" onclick="wczNavCta()">
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
      <span id="wcz-nav-cart-label">Order</span>
      <span class="wcz-nav-cart-count" id="wcz-nav-cart-count" style="display:none">0</span>
    </button>
  </div>
  <div class="nav-ham" id="nav-ham" aria-label="Open menu">
    <span></span><span></span><span></span>
  </div>
</nav>

<!-- MOBILE NAV -->
<div id="nav-mob">
  <span class="mob-close" id="mob-close">&#x2715;</span>
  <a href="#about" class="mob-link">About</a>
  <a href="#ministries" class="mob-link">Ministries</a>
  <a href="#events" class="mob-link">Events</a>
  <a href="#give" class="mob-link">Give</a>
  {{#if has_products}}<a href="#shop" class="mob-link">Shop</a>{{/if}}
  <a href="#contact" class="mob-link">Contact</a>
  <button onclick="wczCartToggle();document.getElementById('nav-mob').classList.remove('open')" style="color:var(--amber);font-family:var(--display);font-size:1.3rem;font-weight:600">My order</button>
</div>

<!-- ALL SECTIONS RENDERED IN ORDER FROM THE EDITOR -->
{{br_ordered_sections_html}}

<!-- FOOTER -->
<footer>
  <div class="wrap">
    <div class="footer-inner">
      <div class="footer-brand">{{business_name}}</div>
      <div class="footer-links">
        <a href="#about">About</a>
        <a href="#ministries">Ministries</a>
        <a href="#events">Events</a>
        <a href="#give">Give</a>
        {{#if has_products}}<a href="#shop">Shop</a>{{/if}}
        <a href="#contact">Contact</a>
      </div>
      <div class="footer-social">
        {{#if has_facebook}}<a href="{{facebook_url}}" target="_blank" rel="noopener" aria-label="Facebook">f</a>{{/if}}

  {{wcz_qv_drawer_html}}
</div>
{{wcz_lb_html}}

<!-- GALLERY LIGHTBOX ELEMENT (bespoke) -->
<div id="lb" role="dialog" aria-modal="true" aria-label="Image viewer">
  <span id="lb-close" aria-label="Close">&#x2715;</span>
  <span id="lb-prev" aria-label="Previous">&#8249;</span>
  <img id="lb-img" src="" alt="">
  <span id="lb-next" aria-label="Next">&#8250;</span>
</div>

<!-- NAV + REVEAL + LIGHTBOX + VIDEO + FILTER JS -->
<script>
(function(){
'use strict';

// ── NAV ────────────────────────────────────────────────
var nav = document.getElementById('nav');
window.addEventListener('scroll', function(){
  nav.classList.toggle('scrolled', window.scrollY > 60);
}, {passive:true});
nav.classList.toggle('scrolled', window.scrollY > 60);

var ham  = document.getElementById('nav-ham');
var mob  = document.getElementById('nav-mob');
var mcls = document.getElementById('mob-close');
if(ham && mob){
  ham.addEventListener('click', function(){ mob.classList.add('open'); });
  if(mcls) mcls.addEventListener('click', function(){ mob.classList.remove('open'); });
  mob.querySelectorAll('a').forEach(function(a){
    a.addEventListener('click', function(){ mob.classList.remove('open'); });
  });
}

// ── REVEAL ─────────────────────────────────────────────
var obs = new IntersectionObserver(function(entries){
  entries.forEach(function(e){
    if(e.isIntersecting){ e.target.classList.add('visible'); obs.unobserve(e.target); }
  });
}, {threshold:0.12});
document.querySelectorAll('.reveal').forEach(function(el){ obs.observe(el); });

// ── GALLERY LIGHTBOX ──────────────────────────────────
var lbEl    = document.getElementById('lb');
var lbImg   = document.getElementById('lb-img');
var lbClose = document.getElementById('lb-close');
var lbPrev  = document.getElementById('lb-prev');
var lbNext  = document.getElementById('lb-next');
var lbItems = [];
var lbIdx   = 0;

if (lbEl) {
  function lbShow(idx){
    lbIdx = ((idx % lbItems.length) + lbItems.length) % lbItems.length;
    lbImg.src = lbItems[lbIdx];
    lbImg.alt = 'Gallery photo '+(lbIdx+1);
    lbEl.classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function lbHide(){
    lbEl.classList.remove('open');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('#br-gallery .g-item').forEach(function(item, i){
    var img = item.querySelector('img');
    if(img) lbItems.push(img.src);
    item.addEventListener('click', function(){ lbShow(i); });
  });

  if(lbClose) lbClose.addEventListener('click', lbHide);
  if(lbPrev)  lbPrev.addEventListener('click', function(){ lbShow(lbIdx-1); });
  if(lbNext)  lbNext.addEventListener('click', function(){ lbShow(lbIdx+1); });
  lbEl.addEventListener('click', function(e){ if(e.target===lbEl) lbHide(); });
  document.addEventListener('keydown', function(e){
    if(!lbEl.classList.contains('open')) return;
    if(e.key==='Escape') lbHide();
    if(e.key==='ArrowLeft') lbShow(lbIdx-1);
    if(e.key==='ArrowRight') lbShow(lbIdx+1);
  });
}

// ── CATEGORY FILTER (SDK cards) ────────────────────────
var filterBar = document.getElementById('wcz-cat-filters');
if (filterBar) {
  filterBar.querySelectorAll('.fr-cat').forEach(function(btn){
    btn.addEventListener('click', function(){
      filterBar.querySelectorAll('.fr-cat').forEach(function(b){ b.classList.remove('active'); });
      btn.classList.add('active');
      var cat = btn.dataset.cat || '';
      document.querySelectorAll('#wcz-products .wcz-prod-card').forEach(function(card){
        card.style.display = (!cat || card.dataset.cat === cat) ? '' : 'none';
      });
    });
  });
}

})();
</script>

<!-- SDK product script injected by render worker -->
{{wcz_products_script}}

</body>
</html>
